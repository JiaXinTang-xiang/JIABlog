---
import type { CollectionEntry, CollectionKey } from 'astro:content'
import { cn } from 'astro-pure/utils'

type Props = {
  id: string
  collection: string
  collections: CollectionEntry<CollectionKey>[]
  class?: string
}

const { id, collection, collections, class: className } = Astro.props
const path = `/${collection}`

const index = collections.findIndex((x) => x.id === id)
const total = collections.length
const current = index + 1

function getPages(current: number, total: number): (number | string)[] {
  if (total <= 9) return Array.from({ length: total }, (_, i) => i + 1)
  const pages: (number | string)[] = [1]
  if (current > 4) pages.push('...')
  const start = Math.max(2, current - 2)
  const end = Math.min(total - 1, current + 2)
  for (let i = start; i <= end; i++) pages.push(i)
  if (current < total - 3) pages.push('...')
  pages.push(total)
  return pages
}

const pages = getPages(current, total)
---

<div class={cn('flex justify-center items-center gap-x-1 flex-wrap', className)}>
  {pages.map((p) => (
    p === '...' ? (
      <span class='px-2 py-1 text-sm text-muted-foreground'>...</span>
    ) : (
      <a
        href={`${path}/${collections[Number(p) - 1].data.slug || collections[Number(p) - 1].id}`}
        class={`px-3 py-1 text-sm rounded-md no-underline transition-colors ${
          Number(p) === current
            ? 'bg-primary text-primary-foreground font-medium'
            : 'text-muted-foreground hover:bg-muted'
        }`}
      >
        {p}
      </a>
    )
  ))}
</div>
