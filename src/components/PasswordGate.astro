---
interface Props {
  password?: string
}

const { password } = Astro.props
---

{password ? (
  <div class='password-gate'>
    <div class='password-gate__locked' id='password-gate-locked'>
      <div class='password-gate__glow'></div>
      <div class='password-gate__card'>
        <div class='password-gate__icon-wrap'>
          <svg class='password-gate__icon' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'>
            <rect x='3' y='11' width='18' height='11' rx='2' ry='2' />
            <path d='M7 11V7a5 5 0 0 1 10 0v4' />
            <circle cx='12' cy='16' r='1' />
          </svg>
        </div>
        <h3 class='password-gate__title'>私密文章</h3>
        <p class='password-gate__hint'>输入密码解锁内容</p>
        <div class='password-gate__form'>
          <div class='password-gate__input-wrap'>
            <input
              type='password'
              id='password-gate-input'
              class='password-gate__input'
              placeholder='请输入密码'
              autocomplete='off'
            />
          </div>
          <button id='password-gate-btn' class='password-gate__btn' type='button' data-password={password}>
            <span class='password-gate__btn-text'>解锁</span>
            <svg class='password-gate__btn-icon' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>
              <line x1='5' y1='12' x2='19' y2='12' />
              <polyline points='12 5 19 12 12 19' />
            </svg>
          </button>
        </div>
        <p class='password-gate__error' id='password-gate-error'></p>
      </div>
    </div>
    <div class='password-gate__content' id='password-gate-content' style='display:none;'>
      <slot />
    </div>
  </div>
) : (
  <slot />
)}

<script>
  const btn = document.getElementById('password-gate-btn')
  const input = document.getElementById('password-gate-input') as HTMLInputElement
  const error = document.getElementById('password-gate-error')
  const locked = document.getElementById('password-gate-locked')
  const content = document.getElementById('password-gate-content')

  if (btn && input && locked && content) {
    const unlock = () => {
      const pwd = input.value.trim()
      if (!pwd) {
        error!.textContent = '请输入密码'
        error!.classList.add('password-gate__error--visible')
        return
      }
      const correct = btn.dataset.password
      if (pwd === correct) {
        locked.classList.add('password-gate__locked--unlocking')
        setTimeout(() => {
          locked.style.display = 'none'
          content.style.display = 'block'
          content.classList.add('password-gate__content--visible')
        }, 300)
      } else {
        error!.textContent = '密码错误，请重试'
        error!.classList.add('password-gate__error--visible')
        input.classList.add('password-gate__input--shake')
        setTimeout(() => input.classList.remove('password-gate__input--shake'), 500)
        input.value = ''
        input.focus()
      }
    }

    btn.addEventListener('click', unlock)
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') unlock()
    })
    input.addEventListener('input', () => {
      error!.classList.remove('password-gate__error--visible')
    })
  }
</script>

<style>
  .password-gate__locked {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 320px;
    border-radius: 1rem;
    overflow: hidden;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .password-gate__locked--unlocking {
    opacity: 0;
    transform: scale(0.98);
  }

  .password-gate__glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 50%, hsl(var(--primary) / 0.08), transparent 60%),
      radial-gradient(ellipse at 80% 50%, hsl(var(--primary) / 0.05), transparent 60%),
      hsl(var(--card) / 0.6);
    backdrop-filter: blur(12px);
    border: 1px solid hsl(var(--border) / 0.6);
    border-radius: 1rem;
  }

  .dark .password-gate__glow {
    background:
      radial-gradient(ellipse at 20% 50%, hsl(var(--primary) / 0.12), transparent 60%),
      radial-gradient(ellipse at 80% 50%, hsl(var(--primary) / 0.08), transparent 60%),
      hsl(var(--card) / 0.4);
  }

  .password-gate__card {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2.5rem 2rem;
    text-align: center;
    max-width: 380px;
    width: 100%;
  }

  .password-gate__icon-wrap {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: hsl(var(--primary) / 0.1);
    margin-bottom: 1.25rem;
    animation: float 3s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  .password-gate__icon {
    width: 24px;
    height: 24px;
    color: hsl(var(--primary));
  }

  .password-gate__title {
    font-size: 1.25rem;
    font-weight: 600;
    color: hsl(var(--foreground));
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
  }

  .password-gate__hint {
    color: hsl(var(--muted-foreground));
    font-size: 0.875rem;
    margin: 0 0 1.5rem;
    line-height: 1.5;
  }

  .password-gate__form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
    max-width: 280px;
  }

  .password-gate__input-wrap {
    position: relative;
  }

  .password-gate__input {
    width: 100%;
    padding: 0.65rem 1rem;
    border: 1px solid hsl(var(--border));
    border-radius: 0.625rem;
    background: hsl(var(--background));
    color: hsl(var(--foreground));
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }

  .password-gate__input:focus {
    border-color: hsl(var(--primary));
    box-shadow: 0 0 0 3px hsl(var(--primary) / 0.1);
  }

  .password-gate__input--shake {
    animation: shake 0.5s ease-in-out;
  }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    20% { transform: translateX(-6px); }
    40% { transform: translateX(6px); }
    60% { transform: translateX(-4px); }
    80% { transform: translateX(4px); }
  }

  .password-gate__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.65rem 1.5rem;
    border: none;
    border-radius: 0.625rem;
    background: hsl(var(--primary));
    color: hsl(var(--primary-foreground));
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
    overflow: hidden;
  }

  .password-gate__btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent, hsl(0 0% 100% / 0.1), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .password-gate__btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px hsl(var(--primary) / 0.3);
  }

  .password-gate__btn:hover::before {
    opacity: 1;
  }

  .password-gate__btn:active {
    transform: translateY(0);
  }

  .password-gate__btn-icon {
    width: 16px;
    height: 16px;
    transition: transform 0.2s;
  }

  .password-gate__btn:hover .password-gate__btn-icon {
    transform: translateX(2px);
  }

  .password-gate__error {
    color: hsl(0 72% 51%);
    font-size: 0.8rem;
    margin-top: 0.5rem;
    min-height: 1.2em;
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity 0.2s, transform 0.2s;
  }

  .dark .password-gate__error {
    color: hsl(0 72% 65%);
  }

  .password-gate__error--visible {
    opacity: 1;
    transform: translateY(0);
  }

  .password-gate__content {
    animation: fadeIn 0.4s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
