---
interface Props {
  password?: string
}

const { password } = Astro.props
---

{password ? (
  <div class='password-gate'>
    <div class='password-gate__locked' id='password-gate-locked'>
      <div class='password-gate__icon'>🔒</div>
      <p class='password-gate__hint'>本文为加密文章，请输入密码查看</p>
      <div class='password-gate__form'>
        <input
          type='password'
          id='password-gate-input'
          class='password-gate__input'
          placeholder='请输入密码'
          autocomplete='off'
        />
        <button id='password-gate-btn' class='password-gate__btn' type='button' data-password={password}>
          解锁
        </button>
      </div>
      <p class='password-gate__error' id='password-gate-error'></p>
    </div>
    <div class='password-gate__content' id='password-gate-content' style='display:none;'>
      <slot />
    </div>
  </div>
) : (
  <slot />
)}

<script>
  const btn = document.getElementById('password-gate-btn')
  const input = document.getElementById('password-gate-input') as HTMLInputElement
  const error = document.getElementById('password-gate-error')
  const locked = document.getElementById('password-gate-locked')
  const content = document.getElementById('password-gate-content')

  if (btn && input && locked && content) {
    const unlock = () => {
      const pwd = input.value.trim()
      if (!pwd) {
        error!.textContent = '请输入密码'
        return
      }
      // 密码通过 data 属性传入，由 Astro 在构建时注入
      const correct = btn.dataset.password
      if (pwd === correct) {
        locked.style.display = 'none'
        content.style.display = 'block'
      } else {
        error!.textContent = '密码错误，请重试'
        input.value = ''
        input.focus()
      }
    }

    btn.addEventListener('click', unlock)
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') unlock()
    })
  }
</script>

<style>
  .password-gate__locked {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 3rem 1.5rem;
    border: 1px solid hsl(var(--border));
    border-radius: 0.75rem;
    background: hsl(var(--card));
    text-align: center;
  }

  .password-gate__icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .password-gate__hint {
    color: hsl(var(--muted-foreground));
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  .password-gate__form {
    display: flex;
    gap: 0.5rem;
    max-width: 320px;
    width: 100%;
  }

  .password-gate__input {
    flex: 1;
    padding: 0.5rem 0.75rem;
    border: 1px solid hsl(var(--input));
    border-radius: 0.5rem;
    background: hsl(var(--background));
    color: hsl(var(--foreground));
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .password-gate__input:focus {
    border-color: hsl(var(--primary));
  }

  .password-gate__btn {
    padding: 0.5rem 1.25rem;
    border: none;
    border-radius: 0.5rem;
    background: hsl(var(--primary));
    color: hsl(var(--primary-foreground));
    font-size: 0.9rem;
    cursor: pointer;
    transition: opacity 0.2s;
    white-space: nowrap;
  }

  .password-gate__btn:hover {
    opacity: 0.9;
  }

  .password-gate__error {
    color: hsl(var(--destructive, 0 84% 60%));
    font-size: 0.85rem;
    margin-top: 0.75rem;
    min-height: 1.2em;
  }
</style>
