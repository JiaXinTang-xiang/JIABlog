  type Lang = 'zh' | 'en'

  function getLang(): Lang {
    return (localStorage.getItem('lang') as Lang) || 'zh'
  }

  function setLang(lang: Lang) {
    localStorage.setItem('lang', lang)
  }

  function applyTranslations(lang: Lang) {
    const t = translations[lang]

    // 1. 翻译带有 data-i18n 属性的元素
    document.querySelectorAll('[data-i18n]').forEach((el) => {
      const key = el.getAttribute('data-i18n')
      if (key && t[key]) {
        el.textContent = t[key]
      }
    })

    // 2. 翻译导航栏菜单项（通过 data-i18n-nav 属性）
    document.querySelectorAll('[data-i18n-nav]').forEach((el) => {
      const key = el.getAttribute('data-i18n-nav')
      if (key && t[key]) {
        el.textContent = t[key]
      }
    })

    // 3. 翻译包含特定文本的元素
    const textMap: Record<string, string> = {
      'China': 'common.china',
      '中国': 'common.china',
      '广西无人机遥测实验室': 'edu.lab',
      'Guangxi UAV Remote Sensing Laboratory': 'edu.lab',
      '成员': 'edu.member',
      'Member': 'edu.member',
      '桂林航天工业学院': 'edu.school',
      'Guilin University of Aerospace Technology': 'edu.school',
      '电子信息工程专业 - 本科': 'edu.major',
      'Electronic Information Engineering - Bachelor': 'edu.major',
      'Sept 2024 - Present': 'edu.date',
      '2024年9月 - 至今': 'edu.date',
    }

    document.querySelectorAll('h2, p').forEach((el) => {
      const text = el.textContent?.trim()
      if (text && textMap[text]) {
        const key = textMap[text]
        if (t[key]) {
          el.textContent = t[key]
        }
      }
    })

    // 4. 翻译版权信息（特殊处理，因为文本较长且在 Timeline 组件中）
    const copyrightTexts = [
      '本站所有原创内容及整体页面设计',
      'All original content and overall page design'
    ]
    document.querySelectorAll('div, p').forEach((el) => {
      const text = el.textContent?.trim()
      if (text && copyrightTexts.some(copyrightText => text.startsWith(copyrightText))) {
        if (t['about.copyright']) {
          el.textContent = t['about.copyright']
        }
      }
    })

    // 更新按钮文字
    const label = document.getElementById('lang-label')
    if (label) {
      label.textContent = lang === 'zh' ? 'EN' : '中'
    }
    // 更新 html lang 属性
    document.documentElement.lang = lang === 'zh' ? 'zh-CN' : 'en'
  }

  function injectLanguageToggle() {
    // 找到主题切换按钮的容器
    const header = document.querySelector('header-component')
    if (!header) return

    const buttonsContainer = header.querySelector('.z-30.flex.gap-x-4')
    if (!buttonsContainer) return

    // 检查是否已经注入过
    if (document.getElementById('lang-toggle')) return

    // 创建语言切换按钮
    const langBtn = document.createElement('button')
    langBtn.id = 'lang-toggle'
    langBtn.className = 'group/dark box-content rounded-md border px-2 py-1 transition-colors hover:bg-border sm:group-[.not-top]:rounded-xl'
    langBtn.innerHTML = `<span id="lang-label" class="text-sm font-medium">${getLang() === 'zh' ? 'EN' : '中'}</span>`
    langBtn.title = getLang() === 'zh' ? 'Switch to English' : '切换到中文'

    // 插入到主题切换按钮前面
    buttonsContainer.insertBefore(langBtn, buttonsContainer.firstChild)

    // 绑定点击事件
    langBtn.addEventListener('click', () => {
      const newLang: Lang = getLang() === 'zh' ? 'en' : 'zh'
      setLang(newLang)
      applyTranslations(newLang)
      langBtn.title = newLang === 'zh' ? 'Switch to English' : '切换到中文'
    })
  }

  function injectTravellingsLink() {
    // 在导航菜单 Update 后面加上开往外链
    const nav = document.querySelector('header-component #headerExpandContent .flex.flex-col')
    if (!nav || document.getElementById('travellings-link')) return

    const wrapper = document.createElement('div')
    wrapper.className = 'relative'
    const link = document.createElement('a')
    link.id = 'travellings-link'
    link.href = 'https://www.travellings.cn/go.html'
    link.target = '_blank'
    link.rel = 'noopener'
    link.title = '开往-友链接力'
    link.className = 'w-full flex-none grow py-2 text-right font-medium transition-none hover:text-primary sm:w-fit sm:px-3'
    link.setAttribute('data-i18n', 'nav.travellings')
    link.textContent = getLang() === 'zh' ? '开往' : 'Travelling'
    wrapper.appendChild(link)

    // 找到 Update 链接后面插入
    const items = nav.querySelectorAll('.relative')
    const lastItem = items[items.length - 1]
    if (lastItem) {
      lastItem.after(wrapper)
    }
  }

  // 初始化
  function init() {
    injectLanguageToggle()
    injectTravellingsLink()
    const currentLang = getLang()
    applyTranslations(currentLang)
  }

  // 页面加载时初始化
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init)
  } else {
    init()
  }

  // 监听 Astro 页面切换事件（SPA 导航时重新应用翻译）
  document.addEventListener('astro:page-load', () => {
    injectLanguageToggle()
    injectTravellingsLink()
    const lang = getLang()
    applyTranslations(lang)
  })
</script>
