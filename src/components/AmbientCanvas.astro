<div id="ambient-toggle" title="开关氛围效果" class="fixed bottom-4 right-4 z-50 w-9 h-9 flex items-center justify-center rounded-full border border-border/40 bg-background/60 backdrop-blur-sm cursor-pointer text-sm opacity-50 hover:opacity-100 transition-opacity select-none">
  <span id="ambient-toggle-icon">🌧️</span>
</div>
<canvas id="ambient-canvas" class="fixed inset-0 z-[2] pointer-events-none"></canvas>

<script>
  {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (prefersReduced.matches) {
      const t = document.getElementById('ambient-toggle');
      if (t) t.style.display = 'none';
    } else {
      const canvas = document.getElementById('ambient-canvas') as HTMLCanvasElement;
      const toggle = document.getElementById('ambient-toggle');
      const icon = document.getElementById('ambient-toggle-icon');
      if (!canvas || !toggle || !icon) throw new Error('ambient elements missing');

      const ctx = canvas.getContext('2d')!;

      let width = 0, height = 0;
      let enabled = localStorage.getItem('ambient') !== 'false';
      let isDark = document.documentElement.classList.contains('dark');
      let animId = 0;

      function resize() {
        width = window.innerWidth;
        height = window.innerHeight;
        canvas.width = width;
        canvas.height = height;
        // also set CSS size so it covers viewport
        canvas.style.width = width + 'px';
        canvas.style.height = height + 'px';
      }

      interface Particle {
        x: number; y: number;
        vx: number; vy: number;
        len: number;
        alpha: number;
        speed: number;
        sway: number; swayPhase: number;
      }

      const particles: Particle[] = [];
      const RAIN_COUNT = 160;
      const PETAL_COUNT = 45;

      function spawnRain(): Particle {
        return {
          x: Math.random() * width * 1.3 - width * 0.15,
          y: Math.random() * -height,
          vx: -0.5 + Math.random() * -0.4,
          vy: 8 + Math.random() * 10,
          len: 10 + Math.random() * 16,
          alpha: 0.15 + Math.random() * 0.25,
          speed: 0, sway: 0, swayPhase: 0,
        };
      }

      function spawnPetal(): Particle {
        return {
          x: Math.random() * width * 1.3 - width * 0.15,
          y: Math.random() * -height * 0.6,
          vx: -0.3 + Math.random() * 0.6,
          vy: 0.5 + Math.random() * 0.9,
          len: 5 + Math.random() * 8,
          alpha: 0.45 + Math.random() * 0.4,
          speed: 0.02 + Math.random() * 0.03,
          sway: 25 + Math.random() * 35,
          swayPhase: Math.random() * Math.PI * 2,
        };
      }

      function reset() {
        particles.length = 0;
        const n = isDark ? PETAL_COUNT : RAIN_COUNT;
        for (let i = 0; i < n; i++) particles.push(isDark ? spawnPetal() : spawnRain());
      }

      function drawRain(p: Particle) {
        ctx.beginPath();
        ctx.moveTo(p.x, p.y);
        ctx.lineTo(p.x + p.vx * 0.5, p.y + p.len);
        ctx.strokeStyle = `rgba(190,220,250,${p.alpha})`;
        ctx.lineWidth = 0.9;
        ctx.stroke();
      }

      const petalColors = [
        'rgba(255,182,193,P)','rgba(255,160,180,P)','rgba(255,192,203,P)',
        'rgba(221,160,221,P)','rgba(255,255,255,P)','rgba(255,218,185,P)',
      ];

      function drawPetal(p: Particle) {
        const sx = Math.sin(p.swayPhase) * p.sway;
        const cx = p.x + sx;
        ctx.save();
        ctx.translate(cx, p.y);
        ctx.rotate(Math.sin(p.swayPhase * 1.3) * 0.35);
        ctx.beginPath();
        ctx.ellipse(0, 0, p.len * 0.5, p.len, 0, 0, Math.PI * 2);
        ctx.fillStyle = petalColors[Math.floor((p.swayPhase * 100) % petalColors.length)].replace('P', String(p.alpha));
        ctx.fill();
        ctx.restore();
      }

      function tick() {
        if (!enabled) { animId = requestAnimationFrame(tick); return; }
        ctx.clearRect(0, 0, width, height);
        for (let i = 0; i < particles.length; i++) {
          const p = particles[i];
          if (isDark) {
            p.swayPhase += p.speed;
            p.y += p.vy;
            if (p.y > height + 30) { particles[i] = spawnPetal(); particles[i].y = -30; }
            drawPetal(p);
          } else {
            p.y += p.vy;
            p.x += p.vx;
            if (p.y > height + 20) { particles[i] = spawnRain(); particles[i].y = -20; }
            drawRain(p);
          }
        }
        animId = requestAnimationFrame(tick);
      }

      function updateIcon() { if (icon) icon.textContent = isDark ? '🌸' : '🌧️'; }

      new MutationObserver(() => {
        const d = document.documentElement.classList.contains('dark');
        if (d !== isDark) { isDark = d; reset(); updateIcon(); }
      }).observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

      toggle.addEventListener('click', () => {
        enabled = !enabled;
        localStorage.setItem('ambient', String(enabled));
        toggle.style.opacity = enabled ? '' : '0.35';
        if (enabled) reset();
      });

      resize();
      reset();
      updateIcon();
      if (!enabled) toggle.style.opacity = '0.35';

      window.addEventListener('resize', () => { resize(); reset(); });
      document.addEventListener('visibilitychange', () => {
        if (!enabled) return;
        if (document.hidden) cancelAnimationFrame(animId);
        else animId = requestAnimationFrame(tick);
      });

      animId = requestAnimationFrame(tick);
    }
  }
</script>
