---
import { Footer, Header, ThemeProvider } from 'astro-pure/components/basic'
import type { SiteMeta } from 'astro-pure/types'
import BaseHead from '@/components/BaseHead.astro'
import config from '@/site-config'

// Import the global.css file here so that it is included on
// all pages through the use of the <BaseLayout /> component.
import '@/assets/styles/global.css'
import '@/assets/styles/app.css'

interface Props {
  meta: SiteMeta
  highlightColor?: string
}

const {
  meta: { articleDate, description = config.description, ogImage, title },
  highlightColor,
  ...props
} = Astro.props
---

<html lang={config.locale.lang}>
  <head>
    <BaseHead {articleDate} {description} {ogImage} {title} />
    <ThemeProvider />
  </head>

  <body class='flex justify-center bg-background text-foreground' {...props}>
    <div id='spotlight' class='pointer-events-none fixed inset-0 z-1'></div>
    {
      highlightColor && (
        <div
          id='highlight-gradient'
          class='pointer-events-none absolute start-0 top-0 z-0 h-screen w-full opacity-25'
          style={`background-image:linear-gradient(${highlightColor},transparent)`}
        />
      )
    }
    <div
      id='main-container'
      class='w-full max-w-[70rem] min-h-[100dvh] flex flex-col justify-between'
    >
      <Header />
      <div class='flex-1 w-full'>
        <slot />
      </div>
      <Footer />
    </div>

    {/* Set highlight color */}
    <style define:vars={{ highlightColor }}>
      :global(.highlight) {
        --highlight-fg: color-mix(
          in srgb,
          var(--highlightColor) 40%,
          hsl(var(--foreground)/var(--un-text-opacity, 1))
        );
        color: var(--highlight-fg, hsl(var(--primary) / var(--un-text-opacity))) !important;
      }
      :global(.highlight-bg) {
        background-color: var(
          --highlightColor,
          hsl(var(--primary) / var(--un-text-opacity))
        ) !important;
      }

      /* Extend safe area for some special screens
       * https://developer.mozilla.org/en-US/docs/Web/CSS/Reference/Values/env
       * https://webkit.org/blog/7929/designing-websites-for-iphone-x/
       */
      #main-container {
        padding-top: env(safe-area-inset-top);
        padding-left: calc(1rem + env(safe-area-inset-left));
        padding-right: calc(1rem + env(safe-area-inset-right));
      }
      @media (min-width: 640px) {
        #main-container {
          padding-left: calc(1.75rem + env(safe-area-inset-left));
          padding-right: calc(1.75rem + env(safe-area-inset-right));
        }
      }
      @media (min-width: 1024px) {
        #main-container {
          padding-left: calc(2.5rem + env(safe-area-inset-left));
          padding-right: calc(2.5rem + env(safe-area-inset-right));
        }
      }
    </style>

    {/* 点击星光闪烁动画 */}
    <style>
      /* 光标光圈 */
      #spotlight {
        background: radial-gradient(
          circle 350px at var(--spot-x, 50%) var(--spot-y, 50%),
          transparent 0%,
          transparent 120px,
          rgba(0, 0, 0, 0.05) 350px
        );
        transition: opacity 0.3s;
      }
      :global(.dark) #spotlight {
        background: radial-gradient(
          circle 350px at var(--spot-x, 50%) var(--spot-y, 50%),
          rgba(255, 235, 180, 0.04) 0%,
          transparent 150px,
          rgba(0, 0, 0, 0.08) 350px
        );
      }

      :global(.sparkle-star) {
        position: fixed;
        pointer-events: none;
        z-index: 9999;
        width: 12px;
        height: 12px;
        clip-path: polygon(50% 0%, 58% 38%, 95% 38%, 65% 55%, 75% 95%, 50% 68%, 25% 95%, 35% 55%, 5% 38%, 42% 38%);
        animation: sparkle-burst 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
        box-shadow: 0 0 6px 2px rgba(255, 215, 0, 0.5);
      }

      :global(.sparkle-dot) {
        position: fixed;
        pointer-events: none;
        z-index: 9998;
        border-radius: 50%;
        animation: dot-fly 0.7s ease-out forwards;
        box-shadow: 0 0 3px 1px rgba(255, 255, 255, 0.6);
      }

      /* 星光颜色 */
      :global(.sparkle-star.color-1) { background: #ffd700; box-shadow: 0 0 6px 2px rgba(255,215,0,0.5); }
      :global(.sparkle-star.color-2) { background: #ffb347; box-shadow: 0 0 6px 2px rgba(255,179,71,0.5); }
      :global(.sparkle-star.color-3) { background: #ffe484; box-shadow: 0 0 6px 2px rgba(255,228,132,0.5); }
      :global(.sparkle-star.color-4) { background: #fff;    box-shadow: 0 0 8px 3px rgba(255,255,255,0.7); }
      :global(.sparkle-star.color-5) { background: #ffcc80; box-shadow: 0 0 6px 2px rgba(255,204,128,0.5); }

      :global(.sparkle-dot.color-1) { background: #ffd700; }
      :global(.sparkle-dot.color-2) { background: #ffe484; }
      :global(.sparkle-dot.color-3) { background: #ffb347; }
      :global(.sparkle-dot.color-4) { background: #fff; }
      :global(.sparkle-dot.color-5) { background: #ffcc80; }

      /* 暗色主题 */
      :global(.dark .sparkle-star.color-1) { background: #ffd700; box-shadow: 0 0 8px 3px rgba(255,215,0,0.5); }
      :global(.dark .sparkle-star.color-2) { background: #ff9f43; box-shadow: 0 0 8px 3px rgba(255,159,67,0.5); }
      :global(.dark .sparkle-star.color-3) { background: #feca57; box-shadow: 0 0 8px 3px rgba(254,202,87,0.5); }
      :global(.dark .sparkle-star.color-5) { background: #f0932b; box-shadow: 0 0 8px 3px rgba(240,147,43,0.5); }

      :global(.dark .sparkle-dot.color-1) { background: #ffd700; }
      :global(.dark .sparkle-dot.color-2) { background: #feca57; }
      :global(.dark .sparkle-dot.color-3) { background: #ff9f43; }
      :global(.dark .sparkle-dot.color-5) { background: #f0932b; }

      @keyframes sparkle-burst {
        0% {
          opacity: 0;
          transform: translate(0, 0) rotate(var(--rot, 0deg)) scale(0);
        }
        20% {
          opacity: 1;
          transform: translate(calc(var(--dx) * 0.2), calc(var(--dy) * 0.2)) rotate(calc(var(--rot, 0deg) * 0.5)) scale(1.3);
        }
        50% {
          opacity: 0.7;
          transform: translate(calc(var(--dx) * 0.60), calc(var(--dy) * 0.60)) rotate(var(--rot, 0deg)) scale(0.8);
        }
        100% {
          opacity: 0;
          transform: translate(var(--dx), var(--dy)) rotate(calc(var(--rot, 0deg) * 1.5)) scale(0);
        }
      }

      @keyframes dot-fly {
        0% {
          opacity: 0;
          transform: translate(0, 0) scale(0.5);
        }
        30% {
          opacity: 0.9;
          transform: translate(calc(var(--dx) * 0.3), calc(var(--dy) * 0.3)) scale(1);
        }
        100% {
          opacity: 0;
          transform: translate(var(--dx), var(--dy)) scale(0.2);
        }
      }
    </style>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)');
        if (prefersReduced.matches) return;

        // 光标光圈跟随
        const spotlight = document.getElementById('spotlight');
        if (spotlight) {
          let ticking = false;
          document.addEventListener('mousemove', (e) => {
            if (!ticking) {
              requestAnimationFrame(() => {
                spotlight.style.setProperty('--spot-x', e.clientX + 'px');
                spotlight.style.setProperty('--spot-y', e.clientY + 'px');
                ticking = false;
              });
              ticking = true;
            }
          });
        }

        let lastClick = 0;

        function createParticle(x: number, y: number, angle: number, distance: number, klass: string, rotDeg: number) {
          const el = document.createElement('div');
          el.className = klass;
          const dx = Math.cos(angle) * distance;
          const dy = Math.sin(angle) * distance;
          el.style.setProperty('--dx', dx + 'px');
          el.style.setProperty('--dy', dy + 'px');
          el.style.setProperty('--rot', rotDeg + 'deg');
          el.style.left = x + 'px';
          el.style.top = y + 'px';
          document.body.appendChild(el);
          setTimeout(() => {
            if (el.parentNode) el.parentNode.removeChild(el);
          }, 850);
        }

        document.addEventListener('click', (e) => {
          const now = Date.now();
          if (now - lastClick < 80) return;
          lastClick = now;

          const baseAngle = Math.random() * Math.PI * 2;
          for (let i = 0; i < 4; i++) {
            const angle = baseAngle + (Math.PI * 2 / 4) * i + (Math.random() - 0.5) * 0.5;
            const distance = 18 + Math.random() * 22;
            const colorIndex = (i % 5) + 1;
            const rot = (Math.random() > 0.5 ? 1 : -1) * (200 + Math.random() * 160);
            setTimeout(() => {
              createParticle(e.clientX, e.clientY, angle, distance, `sparkle-star color-${colorIndex}`, rot);
            }, i * 40);
          }
          for (let i = 0; i < 3; i++) {
            const angle = Math.random() * Math.PI * 2;
            const distance = 6 + Math.random() * 14;
            const colorIndex = Math.floor(Math.random() * 5) + 1;
            setTimeout(() => {
              createParticle(e.clientX, e.clientY, angle, distance, `sparkle-dot color-${colorIndex}`, 0);
            }, 60 + i * 30);
          }
        });
      });
    </script>
  </body>
</html>
