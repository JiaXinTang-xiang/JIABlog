---
import type { GetStaticPaths } from 'astro'
import type { CollectionEntry } from 'astro:content'

import { PostPreview } from 'astro-pure/components/pages'
import { sortMDByDate } from 'astro-pure/server'
import { Button } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import config from '@/site-config'

export const prerender = true

export const getStaticPaths = (async () => {
  const { getCollection } = await import('astro:content')
  const collections = sortMDByDate(await getCollection('update'))
  return [{
    params: {},
    props: { collections }
  }]
}) satisfies GetStaticPaths

interface Props {
  collections: CollectionEntry<'update'>[]
}

const { collections } = Astro.props

const meta = {
  description: '博客更新日志 - 记录功能更新和改进',
  title: '更新日志'
}
---

<PageLayout {meta}>
  <Button title='Back' href='/' variant='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 mt-6 text-3xl font-medium sm:mt-10'>更新日志</h1>
      <p class='text-muted-foreground'>记录博客功能更新和改进历程</p>
    </div>

    <div class='animate' id='content'>
      {
        !collections || collections.length === 0 ? (
          <p class='text-center text-muted-foreground py-8'>暂无更新日志。</p>
        ) : (
          <div class='flex flex-col gap-y-4'>
            {collections.map((post) => (
              <PostPreview {post} />
            ))}
          </div>
        )
      }
    </div>
  </main>
</PageLayout>