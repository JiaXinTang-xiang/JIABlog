---
import { Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'

const headings = [
  { depth: 2, slug: 'update-log', text: '更新日志' }
]
---

<PageLayout title='更新日志' {headings}>

  <h2 id='update-log'>更新记录</h2>

  <Timeline
    events={[
      {
        date: '2026-05-21',
        content: '页面美化：404 页面重设计加入 glitch 动画，搜索页卡片化，更新日志改用时间轴，代码块与全局表格样式增强。'
      },
      {
        date: '2026-05-19',
        content: '全站视觉细节优化：阅读进度条、暗色模式平滑过渡、链接下划线滑入动画、卡片图片悬停微放大。'
      },
      {
        date: '2026-05-09',
        content: '增强光标粒子特效：新增心形、花瓣、圆环、光晕等多种粒子类型，加入标题悬停光晕与鼠标轨迹尾巴效果。'
      },
      {
        date: '2026-05-01',
        content: '创建鼠标点击动画效果：优化水波纹效果，减小动画范围提升用户体验。'
      },
      {
        date: '2026-04-07',
        content: '购买域名并部署上线，网站有了正式别名。'
      },
      {
        date: '2026-04-01',
        content: '搭建个人博客：使用 Astro + astro-theme-pure 主题，记录学习与生活点滴。'
      }
    ]}
  />
</PageLayout>
