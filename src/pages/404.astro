---
import { Button } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'

const meta = {
  description: '页面未找到',
  title: '404'
}
---

<PageLayout {meta}>
  <div class='flex flex-col items-center justify-center px-4 py-16 text-center sm:px-6 lg:px-8'>
    <h1 class='glitch-text text-8xl font-black tracking-tight sm:text-9xl' data-text='404'>
      404
    </h1>
    <p class='mt-6 text-xl font-medium text-foreground'>页面走丢了</p>
    <p class='mt-2 max-w-md text-muted-foreground'>
      你访问的页面不存在或已被移动。检查一下链接，或者回首页看看。
    </p>
    <Button title='返回首页' href='/' variant='ahead' class='mt-8' />
  </div>
</PageLayout>

<style>
  .glitch-text {
    position: relative;
    display: inline-block;
    color: var(--highlightColor, hsl(var(--primary)));
    text-shadow: 0 0 20px color-mix(in srgb, var(--highlightColor, #659EB9) 40%, transparent);
  }
  .glitch-text::before,
  .glitch-text::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    color: var(--highlightColor, hsl(var(--primary)));
  }
  .glitch-text::before {
    animation: glitch-1 2.5s infinite;
    clip-path: polygon(0 0, 100% 0, 100% 35%, 0 35%);
    opacity: 0.6;
  }
  .glitch-text::after {
    animation: glitch-2 3s infinite;
    clip-path: polygon(0 65%, 100% 65%, 100% 100%, 0 100%);
    opacity: 0.4;
    color: #ff6b9d;
  }

  @keyframes glitch-1 {
    0%, 100% { transform: translate(0); }
    20% { transform: translate(-3px, 2px); }
    40% { transform: translate(3px, -1px); }
    60% { transform: translate(-1px, 0); }
    80% { transform: translate(2px, -2px); }
  }
  @keyframes glitch-2 {
    0%, 100% { transform: translate(0); }
    25% { transform: translate(2px, -1px); }
    45% { transform: translate(-2px, 0); }
    65% { transform: translate(0, 2px); }
    85% { transform: translate(-1px, -1px); }
  }
</style>
