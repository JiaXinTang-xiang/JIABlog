---
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'

import { Paginator, PostPreview } from 'astro-pure/components/pages'
import { getUniqueTagsWithCount, sortMDByDate } from 'astro-pure/server'
import { Button, Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import config from '@/site-config'

export const prerender = true

export const getStaticPaths = (async ({ paginate }) => {
  const { getCollection } = await import('astro:content')
  const collections = sortMDByDate(await getCollection('tech'))
  const uniqueTags = getUniqueTagsWithCount(collections).map(([tag]) => tag)
  const collectionsCount = collections.length
  return paginate(collections, {
    pageSize: config.content.blogPageSize,
    props: { uniqueTags, collectionsCount }
  })
}) satisfies GetStaticPaths

interface Props {
  page: Page<CollectionEntry<'tech'>>
  uniqueTags: string[]
  collectionsCount: number
}

const { page, uniqueTags, collectionsCount } = Astro.props

const meta = {
  description: '技术分享与学习记录',
  title: '技术文章'
}

function getPageNumbers(current: number, total: number): (number | string)[] {
  if (total <= 9) return Array.from({ length: total }, (_, i) => i + 1)
  const pages: (number | string)[] = [1]
  if (current > 4) pages.push('...')
  for (let i = Math.max(2, current - 2); i <= Math.min(total - 1, current + 2); i++) pages.push(i)
  if (current < total - 3) pages.push('...')
  pages.push(total)
  return pages
}

const totalPages = Math.ceil(collectionsCount / config.content.blogPageSize)
const pageNumbers = getPageNumbers(page.currentPage, totalPages)
---

<PageLayout {meta}>
  <Button title='Back' href='/' variant='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 mt-6 text-3xl font-medium sm:mt-10'>技术文章</h1>
      <p class='text-muted-foreground'>记录技术学习与成长</p>
    </div>
    {
      page.data.length === 0 ? (
        <p>暂无技术文章。</p>
      ) : (
        <div class='grid gap-y-16 sm:grid-cols-[3fr_1fr] sm:gap-x-8'>
          <section aria-label='Tech posts list' class='animate' id='content'>
            {/* header */}
            <div class='mb-3 flex flex-col justify-between text-sm sm:mb-5 sm:flex-row'>
              <span class='text-muted-foreground'>
                第 {page.currentPage} 页 - 显示 {page.data.length} 篇文章，共 {collectionsCount} 篇
              </span>
              <a aria-label='按年份查看所有技术文章' href='/archives' data-astro-prefetch>
                按年份查看 →
              </a>
            </div>
            {/* posts */}
            <ul class='flex flex-col gap-y-4 text-start'>
              {page.data.map((post) => (
                <PostPreview {post} detailed />
              ))}
            </ul>
            <nav class='mt-6 flex justify-center items-center gap-x-1 flex-wrap'>
              {pageNumbers.map((n) => (
                n === '...' ? (
                  <span class='px-3 py-1.5 text-sm text-muted-foreground'>...</span>
                ) : (
                  <a
                    href={n === 1 ? '/tech/' : `/tech/page/${n}/`}
                    class={`px-3 py-1.5 text-sm rounded-md no-underline transition-colors ${
                      n === page.currentPage
                        ? 'bg-primary text-primary-foreground font-medium'
                        : 'text-muted-foreground hover:bg-muted'
                    }`}
                  >
                    {n}
                  </a>
                )
              ))}
            </nav>
          </section>

          {/* sidebar */}
          {!!uniqueTags.length && (
            <aside class='animate' id='sidebar'>
              <h2 class='mb-4 flex items-center text-lg font-medium'>
                <Icon name='tag-2' class='me-2' />
                Tags
              </h2>
              <ul class='text-bgColor flex flex-wrap gap-2'>
                {
                  // Only show top 50 tags in sidebar
                  uniqueTags.slice(0, 50).map((tag) => (
                    <li>
                      <Button title={tag} href={`/tags/${tag}`} variant='pill' />
                    </li>
                  ))
                }
              </ul>
              <span class='mt-4 block sm:text-end'>
                <a aria-label='View all tech categories' href='/tags' data-astro-prefetch>
                  View all →
                </a>
              </span>
            </aside>
          )}
        </div>
      )
    }
  </main>
</PageLayout>