---
import links from 'public/links.json'

import { Collapse, Timeline } from 'astro-pure/user'
import config from 'virtual:config'
import PageLayout from '@/layouts/CommonPage.astro'
import FriendList from '@/components/links/FriendList.astro'

const headings = [
  { depth: 2, slug: 'common-links', text: 'Common Links' },
  { depth: 2, slug: 'apply-links', text: 'Apply Links' }
]

const { friends } = links
const linksConf = config.integ.links
const linkEditPage = 'https://github.com/cworld1/astro-theme-pure/blob/main/public/links.json'
---

<PageLayout title='Links' {headings} comment>
  <p>They're sorted randomly.</p>
  <h2 id='common-links'>Common Links</h2>
  <FriendList list={friends[0]} />
  <!-- <Collapse title='Links with Bad Status'>
    <FriendList list={friends[1]} />
  </Collapse>
  <Collapse title='Link History Book'>
    <Timeline events={linksConf.logbook} />
  </Collapse> -->

  <h2 id='apply-links'>Apply Links</h2>
  <p>本站信息（点击复制）The site information (click to copy)：</p>
  <blockquote class='not-prose grid grid-cols-[auto_1fr] gap-x-2 break-words border-s-4 ps-4'>
    {
      linksConf.applyTip.map(({ name, val }) => {
        const script = `navigator.clipboard.writeText('${val}');document.dispatchEvent(new CustomEvent('toast',{detail:{message:'Copied "${val}" to clipboard!'}}))`
        return (
          <>
            <span class='text-end'>{name}:</span>
            <samp class='cursor-pointer' onclick={script}>
              {val}
            </samp>
          </>
        )
      })
    }
  </blockquote>

  <div class="my-6 rounded-xl bg-slate-50 dark:bg-slate-800/50 p-5 shadow-sm border border-slate-200 dark:border-slate-700">
  <p class="text-base md:text-lg text-slate-700 dark:text-slate-300 leading-relaxed">
    可通过下方留言或 <a href={linkEditPage} target="_blank" class="font-medium text-blue-600 dark:text-blue-400 hover:underline">提交 PR</a> 申请友链。
    <span class="text-sm text-slate-500 dark:text-slate-400">申请说明：</span>
  </p>
  <p class="mt-1 text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
    Apply via comment or <a href={linkEditPage} target="_blank" class="font-medium text-blue-600 dark:text-blue-400 hover:underline">submitting a PR</a>.
    Requirements:
  </p>

  <ul class="mt-4 space-y-2 pl-1">
    <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
      <span class="text-green-500 mt-0.5">✅</span>
      已在你的友链中添加本站
      <span class="text-slate-500 dark:text-slate-400 ml-1">Add our link first</span>
    </li>
    <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
      <span class="text-green-500 mt-0.5">✅</span>
      站点可正常访问 + 拥有独立域名
      <span class="text-slate-500 dark:text-slate-400 ml-1">Site alive + valid domain</span>
    </li>
    <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
      <span class="text-green-500 mt-0.5">✅</span>
      内容合法合规，无违规信息
      <span class="text-slate-500 dark:text-slate-400 ml-1">Legal & friendly content</span>
    </li>
  </ul>
</div>


  <!-- <p>
    可通过下方留言或 <a href={linkEditPage} target='_blank'>提交 PR</a> 申请友链。申请说明：<br />
    Apply your link by leaving comment or <a href={linkEditPage} target='_blank'>Submitting a PR</a
    >. Additional info:
  </p>
  <ul>
    <li>在你的友链上推荐了本站 You've recommended our link on your website</li>
    <li>站点活着且有正式域名 Make sure your site is alive with a formal domain</li>
    <li>内容不违反国家法律 Content does not violate laws</li>
  </ul> -->



</PageLayout>
