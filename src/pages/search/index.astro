---
import { PFSearch } from 'astro-pure/components/pages'
import { Button, Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import { integ } from '@/site-config'

const meta = {
  description: '搜索全站文章',
  title: 'Search'
}
---

<PageLayout {meta}>
  <Button title='返回' href='/blog' variant='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-2 text-3xl font-medium'>搜索</h1>
      <p class='text-muted-foreground'>输入关键词搜索博客文章。</p>
    </div>

    <div id='content' class='animate mt-8'>
      {
        integ.pagefind ? (
          <div class='rounded-xl border bg-card/50 p-6 sm:p-8'>
            <PFSearch />
          </div>
        ) : (
          <div class='flex flex-col items-center gap-4 rounded-xl border bg-card/50 px-6 py-16 text-center'>
            <Icon name='search' class='size-10 text-muted-foreground' />
            <p class='text-muted-foreground'>搜索功能暂未启用。</p>
          </div>
        )
      }
    </div>
  </main>
</PageLayout>
