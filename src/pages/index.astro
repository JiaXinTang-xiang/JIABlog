---
import { Image } from 'astro:assets'

import { Quote } from 'astro-pure/advanced'
import { Button, Card, Icon, Label } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import ProjectCard from '@/components/home/ProjectCard.astro'
import Section from '@/components/home/Section.astro'
import SkillLayout from '@/components/home/SkillLayout.astro'
import config from '@/site-config'

const languages = ['HTML', 'CSS', 'JavaScript', 'TypeScript']
const frontend = ['React', 'Vue.js', 'Astro', 'Tailwind CSS']
const backend = ['Node.js', 'Express', 'MongoDB', 'Vercel']


const imagePath = config.logo.src
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/*.{jpeg,jpg,png,gif,avif,webp}'
)
if (!images[imagePath])
  throw new Error(
    `"${imagePath}" does not exist in glob: "src/assets/*.{jpeg,jpg,png,gif,avif,webp}"`
  )
---

<PageLayout meta={{ title: 'Home' }} highlightColor='#659EB9'>
  <main class='flex w-full flex-col items-center'>
    <section class='animate mb-10 flex flex-col items-center gap-y-7' id='content-header'>
      <Image
        src={images[imagePath]()}
        alt={config.logo.alt || 'Profile'}
        class='h-28 w-auto rounded-full border p-1'
        loading='eager'
        fetchpriority='high'
      />

      <div class='flex flex-col items-center gap-y-4'>
        <h1 class='text-3xl font-medium'>{config.author}</h1>
        <div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
          <Label title='China'>
            <Icon name='location' class='size-5' slot='icon' />
          </Label>
          <Label
            title='GitHub'
            as='a'
            href='https://github.com/jiaxintang-xiang'
            target='_blank'
          >
            <Icon name='github' class='size-5' slot='icon' />
          </Label>
          <Label
            title='Email'
            as='a'
            href='mailto:2174064279@qq.com'
            target='_blank'
          >
            <Icon name='email' class='size-5' slot='icon' />
          </Label>
        </div>
      </div>

      <!-- {/* Get template */}
      <a
        href='https://github.com/cworld1/astro-theme-pure'
        target='_blank'
        class='flex flex-row items-center gap-x-3 rounded-full border bg-background px-4 py-2 text-sm shadow-sm transition-shadow hover:shadow-md'
      >
        <span class='relative flex items-center justify-center'>
          <span
            class='absolute size-2 animate-ping rounded-full border border-green-400 bg-green-400 opacity-75'
          ></span>
          <span class='size-2 rounded-full bg-green-400'></span>
        </span>
        <p class='font-medium text-muted-foreground'>Get Template</p>
      </a>
    </section> -->

    <div id='content' class='animate flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
      <Section title='About'>
        <p class='text-muted-foreground'>学生/</p>
        <p class='text-muted-foreground'>
        这里分享自己的学习和成长经历。Feel free to contact me~
        </p>
        <Button title='Learn more' class='w-fit self-end' href='/about' variant='ahead' />
      </Section>

      <Section title='Education'>
        <Card
          as='a'
          heading='广西无人机遥测实验室'
          subheading='成员'
          date='Sept 2024 - Present'
        >
        </Card>
        <Card
          as='a'
          heading='桂林航天工业学院'
          subheading='电子信息工程专业 - 本科'
          date='Sept 2024 - Present'
          href='https://dept4.guat.edu.cn/'
        >
           <!-- <ul class='ms-4 list-disc text-muted-foreground'>
            <li>主修课程：数据结构、算法设计、Web开发、数据库系统</li>
            <li>获得奖学金：校级一等奖学金</li>

            <li>参与多个前端项目开发，积累实战经验</li>
          </ul>  -->
        </Card>
      </Section>

      <Section title='Posts'>
        <div class='flex flex-col gap-y-3'>
          <div class='flex flex-col gap-y-1.5 sm:gap-y-2'>
            <div class='post-preview group/card flex flex-col relative rounded-xl border bg-background transition-colors ease-in-out px-4 py-3 hover:bg-muted'>
              <a class='group/link w-full flex flex-col transition-all hover:text-primary sm:flex-row' href='/tech/use-git'>
                <span class='text-muted-foreground font-mono min-w-[95px] py-1 text-xs'>
                  <time datetime='2026-04-07T00:00:00.000Z'>2026年4月7日</time>
                </span>
                <div class='z-10 flex-grow'>
                  <div class='flex justify-between'>
                    <div>Git的常见使用</div>
                    <svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' class='preview-redirect my-1 stroke-muted-foreground group-hover/link:stroke-primary'>
                      <line x1='5' y1='12' x2='19' y2='12' class='translate-x-4 scale-x-0 transition-all duration-300 ease-in-out group-hover/link:translate-x-1 group-hover/link:scale-x-100'></line>
                      <polyline points='12 5 19 12 12 19' class='translate-x-0 transition-all duration-300 ease-in-out group-hover/link:translate-x-1'></polyline>
                    </svg>
                  </div>
                </div>
              </a>
            </div>
            <div class='post-preview group/card flex flex-col relative rounded-xl border bg-background transition-colors ease-in-out px-4 py-3 hover:bg-muted'>
              <a class='group/link w-full flex flex-col transition-all hover:text-primary sm:flex-row' href='/tech/About-Ubuntu%27s-command'>
                <span class='text-muted-foreground font-mono min-w-[95px] py-1 text-xs'>
                  <time datetime='2026-04-14T00:00:00.000Z'>2026年4月14日</time>
                </span>
                <div class='z-10 flex-grow'>
                  <div class='flex justify-between'>
                    <div>Ubuntu常用命令大全</div>
                    <svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' class='preview-redirect my-1 stroke-muted-foreground group-hover/link:stroke-primary'>
                      <line x1='5' y1='12' x2='19' y2='12' class='translate-x-4 scale-x-0 transition-all duration-300 ease-in-out group-hover/link:translate-x-1 group-hover/link:scale-x-100'></line>
                      <polyline points='12 5 19 12 12 19' class='translate-x-0 transition-all duration-300 ease-in-out group-hover/link:translate-x-1'></polyline>
                    </svg>
                  </div>
                </div>
              </a>
            </div>
            <div class='post-preview group/card flex flex-col relative rounded-xl border bg-background transition-colors ease-in-out px-4 py-3 hover:bg-muted'>
              <a class='group/link w-full flex flex-col transition-all hover:text-primary sm:flex-row' href='/monthly/26_4_27'>
                <span class='text-muted-foreground font-mono min-w-[95px] py-1 text-xs'>
                  <time datetime='2024-04-27T00:00:00.000Z'>2024年4月27日</time>
                </span>
                <div class='z-10 flex-grow'>
                  <div class='flex justify-between'>
                    <div>月记·26-04</div>
                    <svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' class='preview-redirect my-1 stroke-muted-foreground group-hover/link:stroke-primary'>
                      <line x1='5' y1='12' x2='19' y2='12' class='translate-x-4 scale-x-0 transition-all duration-300 ease-in-out group-hover/link:translate-x-1 group-hover/link:scale-x-100'></line>
                      <polyline points='12 5 19 12 12 19' class='translate-x-0 transition-all duration-300 ease-in-out group-hover/link:translate-x-1'></polyline>
                    </svg>
                  </div>
                </div>
              </a>
            </div>
            <div class='post-preview group/card flex flex-col relative rounded-xl border bg-background transition-colors ease-in-out px-4 py-3 hover:bg-muted'>
              <a class='group/link w-full flex flex-col transition-all hover:text-primary sm:flex-row' href='/tech/about-my-blog'>
                <span class='text-muted-foreground font-mono min-w-[95px] py-1 text-xs'>
                  <time datetime='2024-04-07T00:00:00.000Z'>2024年4月7日</time>
                </span>
                <div class='z-10 flex-grow'>
                  <div class='flex justify-between'>
                    <div>关于我的博客</div>
                    <svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' class='preview-redirect my-1 stroke-muted-foreground group-hover/link:stroke-primary'>
                      <line x1='5' y1='12' x2='19' y2='12' class='translate-x-4 scale-x-0 transition-all duration-300 ease-in-out group-hover/link:translate-x-1 group-hover/link:scale-x-100'></line>
                      <polyline points='12 5 19 12 12 19' class='translate-x-0 transition-all duration-300 ease-in-out group-hover/link:translate-x-1'></polyline>
                    </svg>
                  </div>
                </div>
              </a>
            </div>
          </div>
          <a class='group inline-flex items-center gap-x-1 rounded-lg bg-muted border px-3 py-2 text-sm text-muted-foreground transition-all hover:bg-primary-foreground no-underline w-fit self-end' href='/blog'>
            <p class='my-0'>Read more articles</p>
            <svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' class='stroke-muted-foreground group-hover:stroke-primary'>
              <line x1='5' y1='12' x2='19' y2='12' class='translate-x-4 scale-x-0 transition-all duration-300 ease-in-out group-hover:translate-x-1 group-hover:scale-x-100'></line>
              <polyline points='12 5 19 12 12 19' class='translate-x-0 transition-all duration-300 ease-in-out group-hover:translate-x-1'></polyline>
            </svg>
          </a>
        </div>
      </Section>

      <Section title='Projects'>
        <div class='grid grid-cols-1 gap-3 sm:grid-cols-2'>
          <ProjectCard
            href='https://github.com/jiaxintang-xiang/JIABlog'
            heading='Personal Blog'
            subheading='A technical blog built with Astro, supporting Markdown, MDX and responsive design'
            imagePath='/src/assets/projects/1.avif'
          />
        </div>
      </Section>

      <Section title='Skills'>
        <SkillLayout title='Programming Languages' skills={languages} />
        <SkillLayout title='Frontend Technologies' skills={frontend} />
        <SkillLayout title='Backend Tools' skills={backend} />
      </Section>

      <Section title='Statistics'>
        <div class='grid grid-cols-2 gap-4 sm:grid-cols-4'>
          <div class='rounded-lg border p-4 text-center'>
            <div class='text-2xl font-bold text-primary'>365</div>
            <div class='text-sm text-muted-foreground'>Days Online</div>
          </div>
          <div class='rounded-lg border p-4 text-center'>
            <div class='text-2xl font-bold text-primary'>2025</div>
            <div class='text-sm text-muted-foreground'>Last Updated</div>
          </div>
          <div class='rounded-lg border p-4 text-center'>
            <div class='text-2xl font-bold text-primary'>15.2k</div>
            <div class='text-sm text-muted-foreground'>Total Words</div>
          </div>
          <div class='rounded-lg border p-4 text-center'>
            <div class='text-2xl font-bold text-primary'>6</div>
            <div class='text-sm text-muted-foreground'>Total Posts</div>
          </div>
        </div>
      </Section>


      <Section>
        <div class="overflow-x-auto">
          <img
            src="https://ghchart.rshah.org/jiaxintang-xiang"
            alt="GitHub Contributions Chart"
            class="h-auto w-full rounded-lg border"
          >
        </div>
          <p class="mt-2 text-left text-sm text-muted-foreground">
            3010 contributions in 2025 ~ 2026
        </p>

     <Quote class='mt-12' />   <!--//Quote 组件的配置 -->

  </main>
</PageLayout>


